rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Menu items: anyone can read, only authenticated admins can write
    match /menu/{itemId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Bakery info: anyone can read, only authenticated admins can write
    match /info/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Orders: anyone can create, only authenticated admins can read/update/delete
    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
  }
}